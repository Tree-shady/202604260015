# ============================================
# 日记本应用 - 环境配置文件
# ============================================

# ---------------------------
# 应用配置
# ---------------------------
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=true

# 应用密钥（用于会话加密）
SECRET_KEY=your-secret-key-here-change-in-production

# 端口配置
PORT=5000
HOST=127.0.0.1

# ---------------------------
# 数据库配置
# ---------------------------
# 默认使用 SQLite 数据库
DATABASE_URL=sqlite:///diary.db

# 如果使用 PostgreSQL（需要安装 psycopg2）
# DATABASE_URL=postgresql://username:password@localhost:5432/diary

# 如果使用 MySQL（需要安装 mysqlclient）
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/diary

# ---------------------------
# 远程数据库配置（可选）
# ---------------------------
# REMOTE_DB_HOST=your-database-host
# REMOTE_DB_PORT=5432
# REMOTE_DB_NAME=diary
# REMOTE_DB_USER=your-username
# REMOTE_DB_PASSWORD=your-password

# ---------------------------
# 文件上传配置
# ---------------------------
# 允许的文件大小限制（字节）
MAX_CONTENT_LENGTH=16777216

# 图片上传目录
UPLOAD_FOLDER=images

# 允许的图片格式
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,webp

# ---------------------------
# 日志配置
# ---------------------------
LOG_LEVEL=INFO
LOG_FILE=app.log

# ---------------------------
# 备份配置
# ---------------------------
BACKUP_FOLDER=backups
BACKUP_INTERVAL=7

# ---------------------------
# 安全配置
# ---------------------------
# 登录失败锁定时间（秒）
LOCKOUT_DURATION=300

# 最大登录尝试次数
MAX_LOGIN_ATTEMPTS=5

# 密码过期时间（天）
PASSWORD_EXPIRE_DAYS=90

# ---------------------------
# API 配置（问候语等）
# ---------------------------
# 问候语API地址（可选）
GREETINGS_API_URL=https://api.example.com/greetings

# ---------------------------
# 开发模式配置
# ---------------------------
# 是否启用自动重载
AUTO_RELOAD=true

# 是否显示SQL查询日志
SQL_ECHO=false
